{
  "name": "learn-graphql-in-2026",
  "private": true,
  "type": "module",
  "workspaces": [
    "service-1",
    "service-2",
    "graphql-server",
    "talk-intro"
  ],
  "scripts": {
    "service-1": "npm --workspace service-1 start",
    "service-2": "npm --workspace service-2 start",
    "graphql-server": "npm --workspace graphql-server start",
    "intro": "npm --workspace talk-intro start",
    "start": "concurrently --names service-1,service-2,graphql,intro --prefix-colors blue,green,magenta,yellow \"npm run service-1\" \"npm run service-2\" \"npm run graphql-server\" \"npm run intro\""
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
